{% load static %}

{# Desktop: real table, sticky header, horizontal scroll if needed #}
<div class="tw-hidden md:tw-block tw-overflow-x-auto">
  <table class="tw-w-full tw-text-sm tw-border-collapse">
    <thead class="tw-bg-slate-50 tw-sticky tw-top-0 tw-z-10">
      <tr class="tw-text-left tw-text-mpd-700">
        <th class="tw-px-4 tw-py-3 tw-font-semibold">Nome</th>
        <th class="tw-px-4 tw-py-3 tw-font-semibold">Concelho</th>
        <th class="tw-px-4 tw-py-3 tw-font-semibold">Zona</th>
        <th class="tw-px-4 tw-py-3 tw-font-semibold tw-text-center">Nº Mesa</th>
        <th class="tw-px-4 tw-py-3 tw-font-semibold tw-text-center">Nº Eleitor</th>
        <th class="tw-px-4 tw-py-3 tw-font-semibold tw-text-center">Estado</th>
        <th class="tw-px-4 tw-py-3 tw-font-semibold tw-text-right">Acção</th>
      </tr>
    </thead>
    <tbody class="tw-divide-y tw-divide-slate-100">
      {% for eleitor in page_obj %}
        <tr class="hover:tw-bg-slate-50 tw-transition">
          <td class="tw-px-4 tw-py-3">
            <div class="tw-flex tw-items-center tw-gap-3">
              <div class="tw-w-9 tw-h-9 tw-rounded-full tw-bg-mpd-100 tw-text-mpd-700 tw-flex tw-items-center tw-justify-center tw-font-semibold tw-text-xs tw-shrink-0">
                {{ eleitor.nome|slice:":1"|upper }}
              </div>
              <div class="tw-min-w-0">
                <div class="tw-font-medium tw-text-slate-800 tw-truncate">{{ eleitor.nome }}</div>
                {% if eleitor.nominho %}<div class="tw-text-xs tw-text-slate-500 tw-truncate">{{ eleitor.nominho }}</div>{% endif %}
              </div>
            </div>
          </td>
          <td class="tw-px-4 tw-py-3 tw-text-slate-700">{{ eleitor.concelho|default:"—" }}</td>
          <td class="tw-px-4 tw-py-3 tw-text-slate-700">{{ eleitor.zona|default:"—" }}</td>
          <td class="tw-px-4 tw-py-3 tw-text-center">
            {% if eleitor.nr_mesa %}
              <span class="tw-inline-flex tw-px-2 tw-py-1 tw-rounded-md tw-bg-slate-100 tw-text-slate-700 tw-text-xs tw-font-medium">{{ eleitor.nr_mesa }}</span>
            {% else %}—{% endif %}
          </td>
          <td class="tw-px-4 tw-py-3 tw-text-center tw-text-slate-700">{{ eleitor.nr_eleitor|default:"—" }}</td>
          <td class="tw-px-4 tw-py-3 tw-text-center">
            {% if eleitor.mpd %}
              <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-1 tw-rounded-full tw-bg-mpd-50 tw-text-mpd-700 tw-text-xs tw-font-medium">
                <span class="tw-w-1.5 tw-h-1.5 tw-rounded-full tw-bg-mpd-500"></span>MPD
              </span>
            {% elif eleitor.indeciso %}
              <span class="tw-inline-flex tw-px-2 tw-py-1 tw-rounded-full tw-bg-amber-50 tw-text-amber-700 tw-text-xs tw-font-medium">Indeciso</span>
            {% else %}
              <span class="tw-text-xs tw-text-slate-400">—</span>
            {% endif %}
          </td>
          <td class="tw-px-4 tw-py-3">
            <div class="tw-flex tw-items-center tw-justify-end tw-gap-1">
              <a href="{% url 'eleitores.view' eleitor.id %}" title="Ver"
                 class="tw-w-8 tw-h-8 tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-text-mpd-700 hover:tw-bg-mpd-50 tw-transition">
                <i class="fa fa-eye"></i>
              </a>
              <a href="{% url 'eleitores.update' eleitor.id %}" title="Editar"
                 class="tw-w-8 tw-h-8 tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-text-slate-600 hover:tw-bg-slate-100 tw-transition">
                <i class="fa fa-edit"></i>
              </a>
              <button type="button" class="js-remove tw-w-8 tw-h-8 tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-text-red-600 hover:tw-bg-red-50 tw-transition"
                      title="Remover" data-id="{{ eleitor.id }}">
                <i class="fa fa-trash"></i>
              </button>
            </div>
          </td>
        </tr>
      {% empty %}
        <tr><td colspan="7" class="tw-py-16 tw-text-center tw-text-slate-500">
          <i class="fa fa-inbox tw-text-3xl tw-block tw-mb-2 tw-text-slate-300"></i>
          Sem resultados
        </td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>

{# Mobile: card list #}
<div class="md:tw-hidden tw-divide-y tw-divide-slate-100">
  {% for eleitor in page_obj %}
    <div class="tw-p-4">
      <div class="tw-flex tw-items-start tw-gap-3">
        <div class="tw-w-10 tw-h-10 tw-rounded-full tw-bg-mpd-100 tw-text-mpd-700 tw-flex tw-items-center tw-justify-center tw-font-semibold tw-shrink-0">
          {{ eleitor.nome|slice:":1"|upper }}
        </div>
        <div class="tw-flex-1 tw-min-w-0">
          <div class="tw-flex tw-items-start tw-justify-between tw-gap-2">
            <div class="tw-min-w-0">
              <div class="tw-font-medium tw-text-slate-800 tw-truncate">{{ eleitor.nome }}</div>
              {% if eleitor.nominho %}<div class="tw-text-xs tw-text-slate-500 tw-truncate">{{ eleitor.nominho }}</div>{% endif %}
            </div>
            {% if eleitor.mpd %}
              <span class="tw-inline-flex tw-items-center tw-gap-1 tw-px-2 tw-py-0.5 tw-rounded-full tw-bg-mpd-50 tw-text-mpd-700 tw-text-xs tw-font-medium tw-shrink-0">
                <span class="tw-w-1.5 tw-h-1.5 tw-rounded-full tw-bg-mpd-500"></span>MPD
              </span>
            {% endif %}
          </div>
          <div class="tw-grid tw-grid-cols-2 tw-gap-x-3 tw-gap-y-1 tw-mt-2 tw-text-xs tw-text-slate-600">
            <div><span class="tw-text-slate-400">Concelho:</span> {{ eleitor.concelho|default:"—" }}</div>
            <div><span class="tw-text-slate-400">Zona:</span> {{ eleitor.zona|default:"—" }}</div>
            <div><span class="tw-text-slate-400">Mesa:</span> {{ eleitor.nr_mesa|default:"—" }}</div>
            <div><span class="tw-text-slate-400">Nº Eleitor:</span> {{ eleitor.nr_eleitor|default:"—" }}</div>
          </div>
          <div class="tw-flex tw-justify-end tw-gap-1 tw-mt-3">
            <a href="{% url 'eleitores.view' eleitor.id %}"
               class="tw-px-3 tw-py-1.5 tw-text-xs tw-rounded-lg tw-text-mpd-700 tw-bg-mpd-50">Ver</a>
            <a href="{% url 'eleitores.update' eleitor.id %}"
               class="tw-px-3 tw-py-1.5 tw-text-xs tw-rounded-lg tw-text-slate-700 tw-bg-slate-100">Editar</a>
            <button type="button" data-id="{{ eleitor.id }}"
                    class="js-remove tw-px-3 tw-py-1.5 tw-text-xs tw-rounded-lg tw-text-red-600 tw-bg-red-50">Apagar</button>
          </div>
        </div>
      </div>
    </div>
  {% empty %}
    <div class="tw-py-12 tw-text-center tw-text-slate-500">
      <i class="fa fa-inbox tw-text-3xl tw-block tw-mb-2 tw-text-slate-300"></i>
      Sem resultados
    </div>
  {% endfor %}
</div>

{# Pagination #}
{% if page_obj.paginator.num_pages > 1 %}
<div class="tw-flex tw-flex-col sm:tw-flex-row tw-items-center tw-justify-between tw-gap-3 tw-px-4 tw-py-3 tw-border-t tw-border-slate-100 tw-bg-slate-50">
  <div class="tw-text-xs tw-text-slate-500">
    Página <span class="tw-font-medium tw-text-slate-700">{{ page_obj.number }}</span>
    de <span class="tw-font-medium tw-text-slate-700">{{ page_obj.paginator.num_pages }}</span>
    · {{ page_obj.paginator.count }} registos
  </div>
  <div class="tw-inline-flex tw-items-center tw-gap-1">
    {% if page_obj.has_previous %}
      <a href="#" data-page="1" class="tw-px-2 tw-py-1.5 tw-text-xs tw-rounded-lg tw-text-slate-600 hover:tw-bg-white">«</a>
      <a href="#" data-page="{{ page_obj.previous_page_number }}" class="tw-px-3 tw-py-1.5 tw-text-xs tw-rounded-lg tw-text-slate-700 hover:tw-bg-white">Anterior</a>
    {% endif %}
    <span class="tw-px-3 tw-py-1.5 tw-text-xs tw-rounded-lg tw-bg-mpd-500 tw-text-white tw-font-medium">{{ page_obj.number }}</span>
    {% if page_obj.has_next %}
      <a href="#" data-page="{{ page_obj.next_page_number }}" class="tw-px-3 tw-py-1.5 tw-text-xs tw-rounded-lg tw-text-slate-700 hover:tw-bg-white">Próxima</a>
      <a href="#" data-page="{{ page_obj.paginator.num_pages }}" class="tw-px-2 tw-py-1.5 tw-text-xs tw-rounded-lg tw-text-slate-600 hover:tw-bg-white">»</a>
    {% endif %}
  </div>
</div>
{% endif %}
